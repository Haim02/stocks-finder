# ============================================================
# stocks-finder — Railway Environment Variables Template
# ============================================================
# Copy every key below into your Railway service → Variables tab.
# Do NOT commit this file with real values to git.
# ============================================================


# ── MongoDB ──────────────────────────────────────────────────
# Railway injects MONGODB_URL automatically when you add the
# MongoDB plugin. Paste your Atlas URI here as a fallback.
MONGODB_URL=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/


# ── OpenAI ───────────────────────────────────────────────────
# Required — the AI agent, GS analyst, and deep-dive all use it.
OPENAI_API_KEY=sk-proj-...


# ── Email — Resend ───────────────────────────────────────────
# Required — all HTML reports are sent via Resend.
RESEND_API_KEY=re_...
FROM_EMAIL=alerts@your-domain.com
ALERT_TO_EMAIL=you@gmail.com


# ── Telegram Bot ─────────────────────────────────────────────
# Required for /scan /status /options /analyze commands.
# Get token from @BotFather. Get chat ID from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=7527624946


# ── Finnhub ──────────────────────────────────────────────────
# Used by FinancialAnalyzer. Free tier is sufficient.
# https://finnhub.io/
FINNHUB_API_KEY=


# ── FRED (Federal Reserve) ───────────────────────────────────
# Free. Used for Fed Rate + CPI macro context in 0DTE prompts.
# https://fred.stlouisfed.org/docs/api/fred/
FRED_API_KEY=


# ── Marketstack ──────────────────────────────────────────────
# Used for corporate actions (splits/dividends) in ML training.
# https://marketstack.com/
MARKETSTACK_API_KEY=


# ── Alpha Vantage ─────────────────────────────────────────────
# Used for crypto momentum (fallback to Finage).
# https://www.alphavantage.co/
ALPHA_VANTAGE_API_KEY=


# ── Finage ───────────────────────────────────────────────────
# Real-time stock + crypto fallback.
# https://finage.co.uk/
FINAGE_API_KEY=


# ── SEC EDGAR ────────────────────────────────────────────────
# Free. Used for CIK lookups and 10-K/10-Q filing dates.
# Format: "FirstName LastName email@domain.com"
SEC_USER_AGENT=Your Name your@email.com


# ── Aletheia (optional) ──────────────────────────────────────
# Institutional ownership override. Leave blank to use the
# free yfinance + SEC EDGAR fallback.
# https://aletheia-ams.com/
ALETHEIA_API_KEY=


# ── Alpaca (optional) ─────────────────────────────────────────
# Used for corporate actions verification.
# https://alpaca.markets/
ALPACA_API_KEY=
ALPACA_API_SECRET=


# ── App / Railway internals ───────────────────────────────────
PORT=8000
WEBHOOK_SECRET=change_me_to_a_random_string

# Railway sets this automatically — do not add it manually.
# RAILWAY_ENVIRONMENT=production
