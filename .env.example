# ============================================================
# stocks-finder — Environment Variables Template
# Copy this file to .env and fill in your actual keys.
# NEVER commit .env to git.
# ============================================================

# ── Core ─────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/
OPENAI_API_KEY=sk-...
FINNHUB_API_KEY=your_finnhub_key

# ── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=alerts@your-domain.com
ALERT_TO_EMAIL=you@gmail.com
DATABASE_URL=sqlite:///./local.db

# ── Premium Market Data ──────────────────────────────────────
# Marketstack — EOD data + corporate actions (splits, dividends)
# https://marketstack.com/
MARKETSTACK_API_KEY=

# Alpha Vantage — Crypto prices, fundamentals
# https://www.alphavantage.co/
ALPHA_VANTAGE_API_KEY=

# Finage — Real-time stock + crypto (fallback)
# https://finage.co.uk/
FINAGE_API_KEY=

# ── US Government / Macro ────────────────────────────────────
# FRED (Federal Reserve Bank of St. Louis) — Fed Rate, CPI, macro series
# https://fred.stlouisfed.org/docs/api/fred/
FRED_API_KEY=

# ── Institutional / SEC ──────────────────────────────────────
# Aletheia (optional) — institutional ownership, short ratio override
# https://aletheia-ams.com/
# Leave blank to use the free yfinance + SEC EDGAR fallback
ALETHEIA_API_KEY=

# Alpaca — used for corporate actions verification (optional)
# https://alpaca.markets/
ALPACA_API_KEY=
ALPACA_API_SECRET=

# ── Telegram Bot (optional — mobile access to the agent) ─────
# Create a bot via @BotFather on Telegram to get the token.
# Get your chat ID by messaging @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── App Settings ─────────────────────────────────────────────
PORT=8000
WEBHOOK_SECRET=optional_secret
